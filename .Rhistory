#Se instalan los paquetes que se van a utilizar
paquetes <- c("readxl","dplyr","stringr","stringi")
#Se cargan las librerias que se van a utilizar
library(readxl) # Esta libreria permite leer archivos Excel
library(dplyr) # Esta libreria realiza la manipulación de datos
library(stringr) #Esta libreria realiza la manipulación de texto
library(stringi) #Esta libreria realiza la  eliminación de acentos
#Definimos la carpeta donde esta nuestra base
setwd("C:/Users/metin/OneDrive/Documentos/AnalistadeDatos")
#Lee el archivo exceld de la base de datos
base <- read_excel("Base para prueba (1) (1).xlsx")
#Realizamos la limpieza de datos duplicados por correo convirtiendo a minusculas y quitando espacios
base <- base %>%
mutate(
Email = str_to_lower(str_trim(Email))
)
#Vemos que participantes tienen Na que significa no asistio para convertirlas a 0 y poder realizar conteo de participaciones
base <- base %>%
mutate(
asistencia_ses1 = ifelse(is.na(asistencia_ses1), 0, asistencia_ses1),
asistencia_ses2 = ifelse(is.na(asistencia_ses2), 0, asistencia_ses2),
asistencia_ses3 = ifelse(is.na(asistencia_ses3), 0, asistencia_ses3),
asistencia_ses4 = ifelse(is.na(asistencia_ses4), 0, asistencia_ses4),
asistencia_ses5 = ifelse(is.na(asistencia_ses5), 0, asistencia_ses5)
)
#Limpiamos nombres y apellidos eliminando basura como espacios textos invalidos:
limpiar_texto <- function(x){
x <- str_trim(x)
x <- ifelse(
is.na(x) |
x == "" |
str_length(x) <= 2 |
str_detect(x, "^(X|IX|NA|N/A)$"),
NA,
x
)
return(x)
}
#Se limpia todas las columnas de nombres
base <- base %>%
mutate(
Nombre = limpiar_texto(Nombre),
`Primer apellido` = limpiar_texto(`Primer apellido`),
`Segundo apellido` = limpiar_texto(`Segundo apellido`)
)
#Agrupa todos los registros que tienen el mismo correo
participantes_unicos <- base %>%
group_by(Email) %>%
summarise(
nombre = first(Nombre),
apellido1 = first(`Primer apellido`),
apellido2 = first(`Segundo apellido`),
sesion1 = max(asistencia_ses1),
sesion2 = max(asistencia_ses2),
sesion3 = max(asistencia_ses3),
sesion4 = max(asistencia_ses4),
sesion5 = max(asistencia_ses5),
.groups = "drop"
)
#Crea la nueva columna y pone el nombre concatenado con primer y segundo apellido
participantes_unicos <- participantes_unicos %>%
mutate(
nombre_completo = paste(nombre, apellido1, apellido2),
nombre_completo = str_squish(nombre_completo)
)
#Realiza limpieza final del nombre para la nueva columna sin acentos y con formato Title Case
participantes_unicos <- participantes_unicos %>%
mutate(
nombre_completo = tolower(nombre_completo),
nombre_completo = str_replace_all(nombre_completo, "[^a-zA-ZáéíóúñÁÉÍÓÚÑ ]", ""),
nombre_completo = stringi::stri_trans_general(nombre_completo, "Latin-ASCII"),
nombre_completo = str_to_title(nombre_completo)
)
#Realiza conteo de asistencias
participantes_unicos <- participantes_unicos %>%
mutate(
total_asistencias =
sesion1 + sesion2 + sesion3 + sesion4 + sesion5
)
#Filtra para ver quien tiene el minimo de asistencias
menor_desempeno <- participantes_unicos %>%
filter(total_asistencias == min(total_asistencias))
#Mostramos en consola el menor desempeño
print(menor_desempeno)
#Exporta lso resultados a un nuevo excel
write.csv(
participantes_unicos,
"participantes_limpios.csv",
row.names = FALSE
)
#Muestra y abre la tabla de Rstudio
View(participantes_unicos)
